const int pirPin = 7, ledPin = 13;
void setup() {
  pinMode(pirPin, INPUT);
  pinMode(ledPin, OUTPUT);
  Serial.begin(9600);
}
void loop() {
  bool motion = digitalRead(pirPin);
  digitalWrite(ledPin, motion);
  Serial.println(motion ? "Motion Detected! LED ON" : "No Motion. LED OFF");
  delay(500);
}

