int count = 0;
void setup() {
  Serial.begin(9600);
  Serial.println("Counter Started!");
}
void loop() {
  count++;
  Serial.print("Count: "); Serial.println(count);
  if (count == 10) { Serial.println(" Reached 10! Resetting..."); count = 0; }
  delay(1000);
}
