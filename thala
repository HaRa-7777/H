const int red = 11, yellow = 10, green = 9;
void setup() {
  pinMode(red, OUTPUT); pinMode(yellow, OUTPUT); pinMode(green, OUTPUT);
  Serial.begin(9600);
}
void light(int pin, const char* msg, int t) {
  digitalWrite(red, LOW); digitalWrite(yellow, LOW); digitalWrite(green, LOW);
  digitalWrite(pin, HIGH); Serial.println(msg); delay(t);
}
void loop() {
  light(red,    "RED    - Stop!",  3000);
  light(yellow, "YELLOW - Ready!", 1000);
  light(green,  "GREEN  - Go!",   3000);
}
