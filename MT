const int ldrPin = A0, ledPin = 9;

void setup() {
  pinMode(ledPin, OUTPUT);
  Serial.begin(9600);
}

void loop() {
  int light = analogRead(ldrPin);
  bool dark = light < 500;
  digitalWrite(ledPin, dark);
  Serial.println(dark ? "Dark! LED ON" : "Bright! LED OFF");
  delay(500);
}
